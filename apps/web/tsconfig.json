{
  "extends": "@poker/config/tsconfig/nextjs",
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "noEmit": true,
    "isolatedModules": true
  },
  "references": [
    {
      "path": "../../packages/shared-types"
    },
    {
      "path": "../../packages/ui"
    }
  ],
  "include": [
    "next-env.d.ts",
    "src/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
