{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm --filter \"@poker/web...\" build"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "pnpm --filter @poker/web start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
