{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm --filter @poker/shared-types build && pnpm --filter @poker/mobile run build"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npx serve apps/mobile/dist --single -p $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
