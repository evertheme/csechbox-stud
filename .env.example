# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
# Railway injects PORT automatically; override only if self-hosting.
PORT=3001
# Optional: override the default listen port used by index.ts
SERVER_PORT=3001

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Expo / web frontend URL in production.
FRONTEND_URL=https://your-app.up.railway.app
CLIENT_ORIGIN=https://your-app.up.railway.app

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars

# ── Redis (optional — server degrades gracefully without it) ──────────────────
REDIS_URL=redis://localhost:6379
