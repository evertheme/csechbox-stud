{
  "extends": "@poker/config/tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    // composite/incremental are for tsc project references; tsup handles
    // bundling and DTS generation itself, so these must be off.
    "composite": false,
    "incremental": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
